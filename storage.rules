rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Admin can upload anything
    match /beats/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024; // 50MB max
    }

    // Covers: images only
    match /beats/covers/{beatId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024; // 10MB
    }

    // Audio: audio files only
    match /beats/audio/{beatId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.contentType.matches('audio/.*')
        && request.resource.size < 50 * 1024 * 1024; // 50MB
    }

    // Previews: audio files only
    match /beats/previews/{beatId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.contentType.matches('audio/.*')
        && request.resource.size < 20 * 1024 * 1024; // 20MB
    }
  }
}
