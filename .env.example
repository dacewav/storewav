# Firebase — copia este archivo a .env y rellena con tus credenciales
# Obtén los valores en: https://console.firebase.google.com → Project Settings → General → Your apps → Web app
#
# En Cloudflare Pages: configura estas mismas vars en el dashboard (Build → Environment variables)
# Son PUBLIC_* → se inlinen en el bundle en build time (no runtime secrets)

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_DATABASE_URL=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# Admin UIDs — comma-separated Firebase UIDs that get admin access
PUBLIC_ADMIN_UIDS=
